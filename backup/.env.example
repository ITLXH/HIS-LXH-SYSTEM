# Backup Environment Configuration Template
# Copy to .env and fill real values. NEVER commit .env!

# ─ GitHub / Repo Config ─────────────────────────────
BACKUP_GH_OWNER=your-org
BACKUP_GH_REPO=HIS-sys-main
BACKUP_GH_TOKEN=ghp_xxxx  # optional, PAT with 'repo' scope

# ─ Google Drive ─────────────────────────────────────
GOOGLE_DRIVE_FOLDER_ID=1AbCdEfGhIjKlMnOpQr  # from folder URL
GOOGLE_DRIVE_CREDENTIALS_JSON='{}'           # service account JSON

# ─ Supabase ─────────────────────────────────────────
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_HOST=db.xxxxx.supabase.co
SUPABASE_PASSWORD=your-db-password
SUPABASE_SERVICE_ROLE_KEY=eyJ...              # from API settings
SUPABASE_STORAGE_BUCKET=database-backups
